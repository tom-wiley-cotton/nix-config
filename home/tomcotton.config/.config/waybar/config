{
    "font-family": ["JetBrainsMono Nerd Font", "Font Awesome", "Roboto"],
    "modules-left": ["custom/menu", "hyprland/workspaces"],
    "modules-center": ["clock", "idle_inhibitor"],
    "modules-right": ["custom/notifications", "custom/copyq", "tray", "custom/scratchpad-indicator", "pulseaudio", "cpu", "memory", "disk", "battery", "custom/power"],

    "hyprland/workspaces": {
        "format": "{name}",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        "on-click": "activate"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ifname} ´âü",
        "format-disconnected": "ţźÉ", 
        "max-length": 50,
        "on-click": "kitty -e 'nmtui'"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ţ░Ľ",
            "deactivated": ""
        }
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "clock": {
        "format": "  {:%d %b %I:%M %p}",
        "on-click": "gnome-calendar"
    },
    "cpu": {
        "format": "{:>03}% {icon}",
        "format-alt": "{avg_frequency:>.1f}GHz {icon}",
        "interval": 1
    },
    "memory": {
        "format": "{:>03}% {icon}",
        "format-alt": "{used:>.1f}GB/{total:>.1f}GB {icon}",
        "interval": 1
    },
    "disk": {
        "format": "{percentage_used}% {icon}´âç",
        "path": "/dev/disk/by-id/ata-WDC_WD10SPZX-60Z10T0_WD-WXS1A9855YLP2",
        "interval": 30
    },
    "battery": {
        "format": "{capacity:>03}% {icon}",
        "format-charging": " {capacity:>03}%",
        "format-plugged": " {capacity:>03}%",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "interval": 30
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "0% {icon}´ÇŽ",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´Çą",
            "headset": "´Çą",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
	"custom/power": {
		"format": "{icon}ÔĆ╗",
		"on-click": "hyprctl dispatch exit"
	},
	"custom/menu": {
		"format": "{icon}ţ«ö",
		"on-click": "rofi -show run -modi drun,run,filebrowser,keys -theme ~/.config/rofi/config.rasi"
	},
    "custom/copyq": {
        "format": " ",
        "on-click": "copyq menu",
        "tooltip": true,
        "interval": 1,
        "exec": "copyq clipboard | head -n 1",
        "max-length": 50
    },
    "custom/scratchpad-indicator": {
        "format-text": "{}hi",
        "return-type": "json",
        "interval": 3,
        "exec": "~/.local/bin/scratchpad-indicator 2> /dev/null",
        "exec-if": "exit 0",
        "on-click": "swaymsg 'scratchpad show'",
        "on-click-right": "swaymsg 'move scratchpad'"
    }
}
